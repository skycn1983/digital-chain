{
  "name": "@digital-chain/js",
  "version": "1.0.0",
  "description": "JavaScript/TypeScript SDK for Digital Chain blockchain",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["blockchain", "cryptocurrency", "digital-chain", "sdk", "javascript", "typescript"],
  "author": "小明",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.0.0",
    "tsup": "^8.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "dependencies": {
    "cross-fetch": "^4.0.0",
    "ws": "^8.0.0",
    "elliptic": "^6.6.0"
  },
  "peerDependencies": {
    "ws": "^8.0.0"
  }
}
