# Digital Chain Testnet Configuration
# Copy this file to .env and customize

# Node Configuration
NODE_ENV=production
PORT=3000
P2P_PORT=30001
DATA_DIR=/data
NODE_ID_SEED=testnet-node

# Seed Nodes (comma-separated)
SEED_NODES=seed.testnet.digitalchain.org:30001

# Blockchain Parameters
DIFFICULTY=2
BLOCK_REWARD=50

# Faucet Configuration
FAUCET_ADDRESS=0xFaucetWalletAddress0000000000000000000000
FAUCET_KEY=your-private-key-here-change-in-production
FAUCET_AMOUNT=1000

# API Authentication (optional)
# API_KEY=your-api-key-here

# Logging
LOG_LEVEL=info
